ANTHROPIC_API_KEY=your_key_here
MONGODB_URI=mongodb://localhost:27017/priceguard
JWT_SECRET=your_jwt_secret_here
PORT=3001
UPLOAD_DIR=./uploads
NODE_ENV=development
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# Stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_BUSINESS_PRICE_ID=price_...

# Gmail OAuth2 (Google Cloud Console)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/gmail/callback
# GOOGLE_PUBSUB_TOPIC=projects/your-project/topics/gmail-push

# Twilio (WhatsApp)
# TWILIO_ACCOUNT_SID=your_sid
# TWILIO_AUTH_TOKEN=your_token
# TWILIO_PHONE_NUMBER=+1234567890

# Optional: Admin notifications (Slack/Discord webhook URL)
# ADMIN_WEBHOOK_URL=https://hooks.slack.com/...
